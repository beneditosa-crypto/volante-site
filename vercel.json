{
  "routes": [
    {
      "src": "/logo.png",
      "dest": "/logo.png",
      "headers": {
        "cache-control": "public, max-age=0, must-revalidate"
      }
    },
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "admin.volante.app.br"
        }
      ],
      "dest": "/admin/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
