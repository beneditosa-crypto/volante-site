{
  "routes": [
    {
      "src": "/anuncio/(.*)",
      "dest": "/anuncio/[id].js"
    },
    {
      "src": "/evento/(.*)",
      "dest": "/evento/[id].js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/detalhe.html",
      "dest": "/detalhe.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
