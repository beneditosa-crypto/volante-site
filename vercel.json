{
  "cleanUrls": true,

  "rewrites": [
    {
      "source": "/anuncio/:slug",
      "destination": "/api/og?tipo=anuncio&slug=:slug"
    },
    {
      "source": "/evento/:slug",
      "destination": "/api/og?tipo=evento&slug=:slug"
    },
    {
      "source": "/share/anuncio/:id",
      "destination": "/api/og?tipo=anuncio&id=:id"
    },
    {
      "source": "/share/evento/:id",
      "destination": "/api/og?tipo=evento&id=:id"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ]
}
