{
  "routes": [
    {
      "src": "/s/([a-zA-Z0-9_-]+)",
      "dest": "/api/s/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/detalhe.html",
      "dest": "/detalhe.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
