{
  "rewrites": [
    {
      "source": "/logo.png",
      "destination": "/logo.png",
      "has": [
        {
          "type": "host",
          "value": "admin.volante.app.br"
        }
      ]
    },
    {
      "source": "/(.*)",
      "destination": "/admin/index.html",
      "has": [
        {
          "type": "host",
          "value": "admin.volante.app.br"
        }
      ]
    }
  ]
}
